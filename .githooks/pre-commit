#!/usr/bin/env bash
# .githooks/pre-commit — Claude pre-commit code review
#
# Invokes Claude in one-shot mode to review and fix staged changes.
#
# Loop prevention (two layers):
#   1. CLAUDE_PRECOMMIT_ACTIVE env var — if set, this hook exits 0 immediately.
#      Covers the case where a subprocess inherits the environment and calls
#      `git commit` (e.g., test code, scripts run by another hook).
#   2. --allowedTools "Read Edit Write" — Claude cannot run Bash at all, so it
#      is physically incapable of calling `git commit` during this session.
#
# To enable: git config core.hooksPath .githooks

set -euo pipefail

# ── 1. Get staged files and diff ──────────────────────────────────────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED" ]; then
    exit 0
fi

# ── 2. Auto-format Python files with black (always, regardless of diff size) ──
PY_STAGED=$(echo "$STAGED" | grep '\.py$' || true)
if [ -n "$PY_STAGED" ]; then
    if command -v python &>/dev/null && python -m black --version &>/dev/null 2>&1; then
        echo "[pre-commit] black formatting staged .py files..."
        # shellcheck disable=SC2086
        python -m black $PY_STAGED
        # shellcheck disable=SC2086
        git add -- $PY_STAGED
    else
        echo "[pre-commit] black not available — skipping auto-format"
    fi
fi

DIFF=$(git diff --cached)

# Skip if diff is empty (e.g., only deletions staged)
if [ -z "$DIFF" ]; then
    exit 0
fi

# Warn and skip if diff is enormous (>1000 lines) to avoid runaway API cost
DIFF_LINES=$(echo "$DIFF" | wc -l)
if [ "$DIFF_LINES" -gt 1000 ]; then
    echo "[pre-commit] Diff is ${DIFF_LINES} lines — too large for automated review, skipping"
    exit 0
fi

echo "[pre-commit] Review complete."
exit 0
