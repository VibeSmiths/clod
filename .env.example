# =============================================================================
# Omni AI Stack — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Ports (uncomment to override defaults)
# -----------------------------------------------------------------------------
OPEN_WEBUI_PORT=8081
TTS_PORT=8002
# NGINX_ROOT_PORT=80
# SEARXNG_PORT=8080
# SD_WEBUI_PORT=7860
# OLLAMA_PORT=11434
# LITELLM_PORT=4000
# PIPELINES_PORT=9099
# CHROMA_PORT=8000

# Default Ollama model for Open-WebUI
DEFAULT_MODEL=qwen2.5-coder:32b-instruct-q4_K_M

# -----------------------------------------------------------------------------
# Local config dirs (relative to repo root, usually don't need changing)
# -----------------------------------------------------------------------------
LITELLM_CONFIG_DIR=./litellm
PIPELINES_DIR=./pipelines
SEARXNG_CONFIG_DIR=./searxng
PERPLEXICA_CONFIG_DIR=./perplexica

# -----------------------------------------------------------------------------
# Data storage (host-side bind-mount paths)
# Windows default: %USERPROFILE%\docker-dependencies
# Linux default:   ~/docker-dependencies
# -----------------------------------------------------------------------------
BASE_DIR=${USERPROFILE}/docker-dependencies

PERPLEXICA_UPLOADS=${BASE_DIR}/perplexica/uploads
PERPLEXICA_DB=${BASE_DIR}/perplexica/db
PIPELINES_DATA=${BASE_DIR}/pipelines/data
N8N_DATA=${BASE_DIR}/n8n/data
CHROMA_DATA=${BASE_DIR}/chroma/data
SD_OUTPUT_DIR=${BASE_DIR}/stablediffusion/outputs
SD_MODELS_DIR=${BASE_DIR}/stablediffusion/models
SD_CKPT_MODELS_DIR=${SD_MODELS_DIR}/ckpt
SD_LORA_MODELS_DIR=${SD_MODELS_DIR}/lora
OWUI_DATA_DIR=${BASE_DIR}/openwebui/data
SEARCH_DIR=${BASE_DIR}/searxng
VOICES_DIR=${BASE_DIR}/voices
TTS_CONFIG_DIR=${BASE_DIR}/tts-config
NGINX_DATA_DIR=${BASE_DIR}/nginx
LE_DATA_DIR=${BASE_DIR}/letsencrypt
OLLAMA_DATA_DIR=${BASE_DIR}/ollama/data

# -----------------------------------------------------------------------------
# Image generation (Stable Diffusion / ComfyUI)
# -----------------------------------------------------------------------------
IMAGE_GENERATION_MODEL=FLUX/flux_dev.safetensors [2eda627c8a]
# IMAGE_GENERATION_ENGINE=automatic1111
# AUTOMATIC1111_CFG_SCALE=7.0
# AUTOMATIC1111_SAMPLER=DPM++ 2M
# AUTOMATIC1111_SCHEDULER=Automatic
# AUTOMATIC1111_API_AUTH=

# ── ComfyUI (video generation) ────────────────────────────────────────────────
# Docker image — yanwk/comfyui-boot:cu124 or ghcr.io/ai-dock/comfyui:latest-cuda
COMFYUI_IMAGE=yanwk/comfyui-boot:cu124
COMFYUI_HOST=comfyui
COMFYUI_PORT=8188
# Model/output dirs — under BASE_DIR by convention
COMFYUI_MODELS_DIR=${BASE_DIR}/comfyui/models
COMFYUI_OUTPUT_DIR=${BASE_DIR}/comfyui/output
COMFYUI_CUSTOM_NODES_DIR=${BASE_DIR}/comfyui/custom_nodes

# -----------------------------------------------------------------------------
# Open-WebUI RAG web search (via SearXNG)
# -----------------------------------------------------------------------------
# ENABLE_RAG_WEB_SEARCH=true
# RAG_WEB_SEARCH_ENGINE=searxng
# RAG_WEB_SEARCH_RESULT_COUNT=3
# RAG_WEB_SEARCH_CONCURRENT_REQUESTS=10
# SEARXNG_HOSTNAME=localhost
# UWSGI_WORKERS=4
# UWSGI_THREADS=4

# -----------------------------------------------------------------------------
# Open-WebUI settings
# -----------------------------------------------------------------------------
ENABLE_SIGNUP=true

# -----------------------------------------------------------------------------
# Secrets — REQUIRED for cloud model access
# -----------------------------------------------------------------------------

# Anthropic API key (used by LiteLLM for claude-sonnet etc.)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# HuggingFace token (for gated models)
HF_TOKEN=hf_YOUR_TOKEN_HERE

# LiteLLM master key (used internally between services — pick any secret string)
LITELLM_MASTER_KEY=sk-local-dev

# -----------------------------------------------------------------------------
# Microsoft SSO (optional — for enterprise Open-WebUI auth)
# -----------------------------------------------------------------------------
# ENABLE_OAUTH_SIGNUP=false
# OAUTH_MERGE_ACCOUNTS_BY_EMAIL=false
# DEFAULT_ROLE_ON_SIGNUP=user
# MICROSOFT_CLIENT_ID=your-client-id-here
# MICROSOFT_CLIENT_SECRET=your-client-secret-here
# MICROSOFT_CLIENT_TENANT_ID=your-tenant-id-here
