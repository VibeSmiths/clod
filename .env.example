# OmniAI environment — copy to .env and fill in values
# cp .env.example .env && chmod 600 .env

# ── LiteLLM gateway ───────────────────────────────────────────────────────────
# Internal auth key OmniAI uses to talk to LiteLLM (set anything you like)
LITELLM_MASTER_KEY=sk-omni-change-this

# Hard spend cap in USD per 30 days across all providers
LITELLM_MAX_BUDGET=20.0

# ── LLM provider API keys ──────────────────────────────────────────────────────
# Add only the ones you have — LiteLLM skips unconfigured providers

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Groq (fast + generous free tier) — https://console.groq.com
GROQ_API_KEY=gsk_...

# Together AI (open-source models) — https://api.together.xyz
TOGETHER_API_KEY=...

# ── Ollama (no key needed — runs locally) ─────────────────────────────────────
OLLAMA_URL=http://host-gateway:11434
